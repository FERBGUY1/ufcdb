# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# API Sports (api-sports.io) — MMA endpoint ~$15/mo
API_SPORTS_KEY=your-api-sports-key
API_SPORTS_BASE=https://v1.mma.api-sports.io

# The Odds API (the-odds-api.com) — free tier available
ODDS_API_KEY=your-odds-api-key
ODDS_API_BASE=https://api.the-odds-api.com/v4

# Anthropic (for AI fight predictions)
ANTHROPIC_API_KEY=your-anthropic-key

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_API_KEY=generate-a-random-string-here

# Scraping (be respectful with delays)
SCRAPE_DELAY_MS=1500
